{
  "name": "gitflare",
  "version": "0.1.1",
  "type": "module",
  "description": "GitHub-shaped developer experience on Cloudflare primitives. Mirror a GitHub repo onto your own Cloudflare account in one command.",
  "license": "MIT",
  "author": "Sina Meraji",
  "homepage": "https://github.com/sinameraji/gitflare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinameraji/gitflare.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sinameraji/gitflare/issues"
  },
  "keywords": [
    "git",
    "github",
    "cloudflare",
    "artifacts",
    "mirror",
    "self-host",
    "workers"
  ],
  "bin": {
    "gitflare": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/bundle-worker.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "wrangler": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "hono": "^4.6.0",
    "isomorphic-git": "^1.27.1",
    "marked": "^14.1.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
