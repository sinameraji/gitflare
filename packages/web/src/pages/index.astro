---
const buildVersion = "0.0.0";
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>GitFlare</title>
    <style>
      :root {
        --bg: #0b0b0c;
        --fg: #e8e8ea;
        --muted: #8b8b91;
        --accent: #f38020;
        --border: #1f1f22;
      }
      html, body { background: var(--bg); color: var(--fg); margin: 0; }
      body {
        font-family: Inter, system-ui, -apple-system, "Segoe UI", sans-serif;
        font-size: 14px;
        line-height: 1.5;
      }
      .wrap { max-width: 880px; margin: 0 auto; padding: 64px 24px; }
      h1 { font-weight: 600; letter-spacing: -0.02em; font-size: 32px; margin: 0 0 8px; }
      .tag { color: var(--accent); font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12px; }
      .muted { color: var(--muted); }
      .status { border: 1px solid var(--border); border-radius: 8px; padding: 16px; margin-top: 24px; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 13px; }
      .row { display: flex; justify-content: space-between; padding: 6px 0; }
      .ok { color: #4ade80; }
      .warn { color: #facc15; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="tag">v{buildVersion} · development</div>
      <h1>GitFlare</h1>
      <p class="muted">
        GitHub stays your source of truth. GitFlare is the faster, always-up mirror
        on your own Cloudflare account.
      </p>

      <div class="status">
        <div class="row"><span>worker</span><span class="warn">not deployed</span></div>
        <div class="row"><span>artifacts repo</span><span class="warn">not provisioned</span></div>
        <div class="row"><span>github webhook</span><span class="warn">not installed</span></div>
        <div class="row"><span>last sync</span><span class="muted">—</span></div>
      </div>

      <p class="muted" style="margin-top: 32px;">
        Run <code style="color: var(--fg);">npx gitflare init &lt;github-url&gt;</code> to provision.
      </p>
    </main>
  </body>
</html>
